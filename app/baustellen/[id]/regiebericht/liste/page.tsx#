"use client";

import { useEffect, useState } from "react";
import Link from "next/link";
import { useParams } from "next/navigation";
import { supabase } from "../../../../lib/supabase";

export default function RegieberichtListePage() {
  const params = useParams();
  const baustelleId = String(params.id);

  const [berichte, setBerichte] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    loadBerichte();
  }, []);

  async function loadBerichte() {
    setLoading(true);

    const { data, error } = await supabase
      .from("regieberichte")
      .select("*")
      .eq("baustelle_id", Number(baustelleId))
      .order("datum", { ascending: false })
      .order("id", { ascending: false });

    if (error) {
      alert("FEHLER BEIM LADEN: " + error.message);
      setLoading(false);
      return;
    }

    const result = [];

    for (const bericht of data || []) {
      const { data: workers } = await supabase
        .from("regiebericht_workers")
        .select("*")
        .eq("regiebericht_id", bericht.id);

      const { data: materials } = await supabase
        .from("regiebericht_materials")
        .select("*")
        .eq("regiebericht_id", bericht.id);

      const { data: rooms } = await supabase
        .from("regiebericht_rooms")
        .select("*")
        .eq("regiebericht_id", bericht.id);

      const { data: photos } = await supabase
        .from("regiebericht_photos")
        .select("*")
        .eq("regiebericht_id", bericht.id);

      const gesamtStunden = (workers || []).reduce((sum, row) => {
        return sum + Number(row.stunden || 0);
      }, 0);

      result.push({
        ...bericht,
        workers: workers || [],
        materials: materials || [],
        rooms: rooms || [],
        photos: photos || [],
        gesamtStunden,
      });
    }

    setBerichte(result);
    setLoading(false);
  }

  async function deleteBericht(id: number) {
    const ok = confirm("Diesen Regiebericht wirklich löschen?");
    if (!ok) return;

    const { error } = await supabase
      .from("regieberichte")
      .delete()
      .eq("id", id);

    if (error) {
      alert("FEHLER BEIM LÖSCHEN: " + error.message);
      return;
    }

    await loadBerichte();
  }

  function formatDate(value: string) {
    if (!value) return "-";

    return new Date(value).toLocaleDateString("de-AT", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    });
  }

  function printPage() {
    window.print();
  }

  return (
    <main style={styles.page}>
      <div className="no-print" style={styles.topLinks}>
        <Link href={`/baustellen/${baustelleId}`} style={styles.backLink}>
          ← Zurück zur Baustelle
        </Link>

        <Link href={`/baustellen/${baustelleId}/regiebericht`} style={styles.newButton}>
          + Neuer Regiebericht
        </Link>
      </div>

      <h1 style={styles.title}>Gespeicherte Regieberichte</h1>

      {loading && <p style={styles.empty}>Wird geladen...</p>}

      {!loading && berichte.length === 0 && (
        <div style={styles.box}>
          <p style={styles.empty}>Noch keine Regieberichte gespeichert.</p>
        </div>
      )}

      {berichte.map((b) => (
        <section key={b.id} style={styles.card}>
          <div style={styles.cardHeader}>
            <div>
              <h2 style={styles.cardTitle}>
                Regiebericht Nr. {b.bericht_nr || b.id}
              </h2>

              <p style={styles.meta}>
                <strong>Datum:</strong> {formatDate(b.datum)}
              </p>

              <p style={styles.meta}>
                <strong>Baustelle:</strong> {b.bauvorhaben || "-"}
              </p>

              <p style={styles.meta}>
                <strong>Ort:</strong> {b.ort || "-"}
              </p>
            </div>

            <div style={styles.rightInfo}>
              <p>
                <strong>Auftraggeber:</strong> {b.auftraggeber || "-"}
              </p>

              <p>
                <strong>Bauleiter:</strong> {b.bauleiter || "-"}
              </p>

              <p>
                <strong>Gesamtstunden:</strong>{" "}
                {Number(b.gesamtStunden || 0).toFixed(2)} h
              </p>
            </div>
          </div>

          <div style={styles.section}>
            <h3 style={styles.sectionTitle}>Ausgeführte Arbeiten</h3>
            <p style={styles.text}>{b.ausgefuehrte_arbeiten || "-"}</p>
          </div>

          {b.rooms.length > 0 && (
            <div style={styles.section}>
              <h3 style={styles.sectionTitle}>Räume / Bauteile</h3>
              <p style={styles.text}>
                {b.rooms.map((r: any) => r.room_name).join(", ")}
              </p>
            </div>
          )}

          <div style={styles.grid}>
            <div style={styles.section}>
              <h3 style={styles.sectionTitle}>Arbeitskräfte</h3>

              {b.workers.length === 0 ? (
                <p style={styles.small}>Keine Arbeitskräfte.</p>
              ) : (
                <table style={styles.table}>
                  <thead>
                    <tr>
                      <th style={styles.th}>Name</th>
                      <th style={styles.th}>von</th>
                      <th style={styles.th}>bis</th>
                      <th style={styles.th}>Std.</th>
                    </tr>
                  </thead>

                  <tbody>
                    {b.workers.map((w: any) => (
                      <tr key={w.id}>
                        <td style={styles.td}>{w.worker_name}</td>
                        <td style={styles.td}>{w.von}</td>
                        <td style={styles.td}>{w.bis}</td>
                        <td style={styles.td}>{w.stunden}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>

            <div style={styles.section}>
              <h3 style={styles.sectionTitle}>Material</h3>

              {b.materials.length === 0 ? (
                <p style={styles.small}>Kein Material.</p>
              ) : (
                <table style={styles.table}>
                  <thead>
                    <tr>
                      <th style={styles.th}>Bezeichnung</th>
                      <th style={styles.th}>Menge</th>
                      <th style={styles.th}>EH</th>
                    </tr>
                  </thead>

                  <tbody>
                    {b.materials.map((m: any) => (
                      <tr key={m.id}>
                        <td style={styles.td}>{m.bezeichnung}</td>
                        <td style={styles.td}>{m.menge}</td>
                        <td style={styles.td}>{m.einheit}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>
          </div>

          {b.photos.length > 0 && (
            <div style={styles.photoGrid}>
              {b.photos.slice(0, 2).map((p: any) => (
                <img
                  key={p.id}
                  src={p.photo_url}
                  alt="Regiebericht Foto"
                  style={styles.photo}
                />
              ))}
            </div>
          )}

          <div className="no-print" style={styles.buttonRow}>
            <button onClick={printPage} style={styles.printButton}>
              Drucken / PDF
            </button>

            <button onClick={() => deleteBericht(b.id)} style={styles.deleteButton}>
              Löschen
            </button>
          </div>
        </section>
      ))}

      <style>{`
        @page {
          size: A4 landscape;
          margin: 8mm;
        }

        @media print {
          .no-print {
            display: none !important;
          }

          body {
            background: white !important;
          }

          main {
            background: white !important;
            color: black !important;
            padding: 0 !important;
          }
        }
      `}</style>
    </main>
  );
}

